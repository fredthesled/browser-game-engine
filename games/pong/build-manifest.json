{
  "game": "pong",
  "title": "Pong",
  "output": "build/pong.html",
  "concat": [
    "engine/engine.bundle.js",
    "scripts/bootstrap.js",
    "scripts/rect-renderer.js",
    "scripts/collider.js",
    "games/pong/scripts/ball.js",
    "games/pong/scripts/paddle-player.js",
    "games/pong/scripts/paddle-ai.js",
    "games/pong/scenes/pong-menu.js",
    "games/pong/scenes/pong-match.js"
  ],
  "bootstrap": "bootstrapGame({ canvasId: 'game', presets: { regular: { w: 800, h: 600 } }, initialScene: (g) => new PongMenuScene(g) });"
}
